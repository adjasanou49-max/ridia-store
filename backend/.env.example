# ================================================================
# RIDIA STORE - Backend Environment Variables
# Copy this file to .env and fill in real values
# ================================================================

NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ---------------- Database ----------------
DATABASE_URL="postgresql://ridia:ridia_password@localhost:5432/ridia_store?schema=public"

# ---------------- Redis (BullMQ + Cache) ----------------
REDIS_URL="redis://localhost:6379"

# ---------------- Auth ----------------
JWT_ACCESS_SECRET="change_this_to_random_64_char_string"
JWT_REFRESH_SECRET="change_this_to_another_random_64_char_string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ---------------- Encryption (for storing seller API keys) ----------------
ENCRYPTION_KEY="32_char_encryption_key_change_me"

# ---------------- Payments: Wave ----------------
WAVE_API_KEY=""
WAVE_MODE="mock"

# ---------------- Payments: Orange Money ----------------
ORANGE_MONEY_CLIENT_ID=""
ORANGE_MONEY_CLIENT_SECRET=""
ORANGE_MONEY_MODE="mock"

# ---------------- Payments: MTN Money ----------------
MTN_MOMO_API_KEY=""
MTN_MOMO_USER_ID=""
MTN_MOMO_SUBSCRIPTION_KEY=""
MTN_MOMO_MODE="mock"

# ---------------- Future API de paiement (à remplir plus tard) ----------------
# Voir backend/src/integrations/payments/CustomPaymentAdapter.ts pour la marche à suivre.
CUSTOM_PAYMENT_API_KEY=""
CUSTOM_PAYMENT_BASE_URL=""
CUSTOM_PAYMENT_MODE="mock"

# ---------------- WhatsApp Business ----------------
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN="ridia_webhook_verify"
WHATSAPP_MODE="mock"

# ---------------- SendGrid (Email) ----------------
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="no-reply@ridia-store.com"
SENDGRID_MODE="mock"

# ---------------- File Storage: AWS S3 / Bunny ----------------
STORAGE_PROVIDER="s3"   # "s3" or "bunny"
AWS_S3_ACCESS_KEY=""
AWS_S3_SECRET_KEY=""
AWS_S3_BUCKET="ridia-store-images"
AWS_S3_REGION="eu-west-1"
BUNNY_API_KEY=""
BUNNY_STORAGE_ZONE=""
BUNNY_PULL_ZONE_URL=""

# ---------------- Product Sourcing Connectors ----------------
ALIBABA_1688_MODE="manual"     # manual | api
ALIBABA_1688_APP_KEY=""
ALIBABA_1688_APP_SECRET=""
TAOBAO_APP_KEY=""
TAOBAO_APP_SECRET=""
PINDUODUO_CLIENT_ID=""
PINDUODUO_CLIENT_SECRET=""

# Currency conversion
CNY_TO_XOF_RATE="90"

# ---------------- Traduction automatique (DeepL) ----------------
# "mock" = dictionnaire basique hors-ligne (dev). "live" = appelle l'API DeepL.
DEEPL_API_KEY=""
TRANSLATION_MODE="mock"
TRANSLATION_DEFAULT_TARGET_LANG="fr"

# ---------------- Agent IA de catégorisation automatique (Claude API) ----------------
# "mock" = heuristique par mots-clés (dev, gratuit). "live" = appelle l'API Anthropic.
ANTHROPIC_API_KEY=""
AI_AGENT_MODE="mock"

# ---------------- Shipping: SinoBurk Cargo ----------------
SINOBURK_API_URL=""
SINOBURK_API_KEY=""

# ---------------- Monitoring ----------------
SENTRY_DSN=""

# ---------------- Rate limiting ----------------
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="200"

# Concurrence du worker d'import - augmente pour un catalogue de centaines de milliers
# à millions de produits. Lance aussi plusieurs conteneurs worker en parallèle pour
# scaler horizontalement (docker-compose up --scale worker=4).
IMPORT_WORKER_CONCURRENCY="10"
